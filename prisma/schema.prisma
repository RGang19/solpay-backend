generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                    String           @id @default(auto()) @map("_id") @db.ObjectId
  name                  String?
  phone                 String           @unique
  wallet_address        String           @unique
  encrypted_private_key String
  is_merchant           Boolean          @default(false)
  created_at            DateTime         @default(now())
  
  // Relations
  sent_transactions     Transaction[]    @relation("Sender")
  received_transactions Transaction[]    @relation("Receiver")
  merchant_requests     PaymentRequest[] @relation("MerchantRequests")
  sessions              Session[]
  notifications         Notification[]
  infra_payments        InfraPayment[]
  auth_challenges       AuthChallenge[]
}

model Transaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  amount      Float
  tx_hash     String   @unique
  status      String   @default("SUCCESS") // SUCCESS, PENDING, FAILED
  token       String   @default("SOL")
  created_at  DateTime @default(now())

  // Relations
  sender_id   String   @db.ObjectId
  sender      User     @relation("Sender", fields: [sender_id], references: [id])
  
  receiver_id String?  @db.ObjectId
  receiver    User?    @relation("Receiver", fields: [receiver_id], references: [id])
}

model PaymentRequest {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  merchant_id String   @db.ObjectId
  merchant    User     @relation("MerchantRequests", fields: [merchant_id], references: [id])
  amount      Float
  token       String   @default("SOL")
  status      String   @default("PENDING") // PENDING, PAID, EXPIRED
  label       String?
  message     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model Session {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  token_hash String   @unique
  user_id    String   @db.ObjectId
  user       User     @relation(fields: [user_id], references: [id])
  expires_at DateTime
  created_at DateTime @default(now())
}

model AuthChallenge {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  wallet_address String
  nonce          String    @unique
  message        String
  used_at        DateTime?
  expires_at     DateTime
  created_at     DateTime  @default(now())

  user_id        String?   @db.ObjectId
  user           User?     @relation(fields: [user_id], references: [id])
}

model Notification {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  user_id    String   @db.ObjectId
  user       User     @relation(fields: [user_id], references: [id])
  type       String
  title      String
  body       String
  data       Json?
  read       Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model InfraPayment {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  user_id           String    @db.ObjectId
  user              User      @relation(fields: [user_id], references: [id])
  amount            Float
  token             String    @default("SOL")
  recipient_address String
  reference         String    @unique
  label             String?
  message           String?
  memo              String?
  status            String    @default("PENDING")
  checkout_url      String
  signature         String?
  confirmed_at      DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
}
